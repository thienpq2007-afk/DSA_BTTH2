#include<iostream>
#include<string>
using namespace std;

void Nhap(string *&A, int &n)
{
    cin >> n;
    cin.ignore();
    A = new string[n];
    for(int i = 0; i < n; i++)
    {
        getline(cin, A[i]);
    }
}

int Binary_Search(string A[], int n, string x)
{
    int left = 0, right = n - 1;

    while (left <= right)
    {
        int mid = (left + right) / 2;
        if (A[mid] == x)
            return mid + 1;
        else if (A[mid] < x)
            left = mid + 1;
        else
            right = mid - 1;
    }
    return -1;
}

int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    string *A;
    int n;
    Nhap(A, n);
    string x;
    getline(cin, x);
    cout << Binary_Search(A, n, x);
    return 0;
}
