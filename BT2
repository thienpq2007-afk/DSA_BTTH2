#include<iostream>
using namespace std;

struct Point
{
    long long x, y, z;
};

void Nhap(Point*& A, long long& n)
{
    cin >> n;
    A = new Point[n];
    for (long long i = 0; i < n; i++)
    {
        cin >> A[i].x >> A[i].y >> A[i].z;
    }
}

void Xuat(Point A[], long long n)
{
    for (long long i = 0; i < n; i++)
    {
        cout << A[i].x << " " << A[i].y << " " << A[i].z << "\n";
    }
}

bool cmp(Point a, Point b)
{
    if (a.x != b.x) return a.x < b.x;
    if (a.y != b.y) return a.y > b.y;
    return a.z < b.z;
}

void QuickSort(Point a[], int l, int r)
{
    int i = l, j = r;
    Point pivot = a[(l + r) / 2];

    while (i <= j)
    {
        while (cmp(a[i], pivot)) i++;
        while (cmp(pivot, a[j])) j--;

        if (i <= j)
        {
            swap(a[i], a[j]);
            i++;
            j--;
        }
    }

    if (l < j) QuickSort(a, l, j);
    if (i < r) QuickSort(a, i, r);
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);

    Point* A;
    long long n;
    Nhap(A, n);

    QuickSort(A, 0, n - 1);

    Xuat(A, n);
    return 0;
}
