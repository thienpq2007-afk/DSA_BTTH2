#include<iostream>
using namespace std;

void TopDownMergeSort(int a[], int l, int r, int n);
void TopDownMerge(int a[], int l, int r);
void Copy(int b[], int a[], int l, int r);

void Nhap(int A[], int& n)
{
	cin >> n;
	for (int i = 0; i < n; i++)
		cin >> A[i];
}

void XuatBuoc(int A[], int n, int l, int r)
{
	for (int i = 0; i < n; i++)
	{
		if (i == l) cout << "[ ";
		cout << A[i] << " ";
		if (i == r) cout << "] ";
	}
	cout << "\n";
}

void MergeSort(int a[], int n) {
	TopDownMergeSort(a, 0, n - 1, n);
}

void TopDownMergeSort(int a[], int l, int r, int n) {
	if (l < r) {
		int mid = (l + r) / 2;
		TopDownMergeSort(a, l, mid, n);
		TopDownMergeSort(a, mid + 1, r, n);
		TopDownMerge(a, l, r);

		XuatBuoc(a, n, l, r);
	}
}

void TopDownMerge(int a[], int l, int r) {
	int nb = r - l + 1;
	int* b = new int[nb];

	Copy(b, a, l, r);

	int mid = (nb - 1) / 2;
	int i0 = 0, i1 = mid + 1;

	for (int j = l; j <= r; j++) {
		if (i0 <= mid && (i1 >= nb || b[i0] <= b[i1]))
			a[j] = b[i0++];
		else
			a[j] = b[i1++];
	}

	delete[] b;
}

void Copy(int b[], int a[], int l, int r) {
	for (int i = 0; i <= r - l; i++)
		b[i] = a[i + l];
}

int main()
{
	int A[1000];
	int n;

	Nhap(A, n);
	MergeSort(A, n);

	return 0;
}
